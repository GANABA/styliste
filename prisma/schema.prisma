// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  STYLIST
  ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIAL
}

// Sprint 3 Enums
enum OrderStatus {
  QUOTE
  IN_PROGRESS
  READY
  DELIVERED
  CANCELED
}

enum UrgencyLevel {
  NORMAL
  HIGH
  URGENT
}

enum FabricProvidedBy {
  CLIENT
  STYLIST
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum PhotoType {
  REFERENCE
  FABRIC
  FITTING
  FINISHED
}

enum OrderChangeType {
  STATUS_CHANGE
  PRICE_CHANGE
  DATE_CHANGE
  DESCRIPTION_CHANGE
  OTHER
}

// Sprint 5 Enums
enum NotificationType {
  ORDER_READY
  PAYMENT_REMINDER
  PICKUP_REMINDER
}

enum NotificationChannel {
  EMAIL
}

enum NotificationStatus {
  SENT
  FAILED
  PENDING
}

// Sprint 4 Enums
enum PaymentType {
  ADVANCE
  PARTIAL
  FINAL
  REFUND
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
}

enum PaymentRecordStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// Models
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      UserRole  @default(STYLIST)
  suspended Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  stylist    Stylist?
  sessions   Session[]
  accounts   Account[]
  auditLogs  AuditLog[]

  @@index([email])
  @@map("users")
}

model Stylist {
  id                  String    @id @default(uuid())
  userId              String    @unique @map("user_id")
  businessName        String?   @map("business_name")
  slug                String?   @unique
  phone               String?
  city                String?
  address             String?
  logoUrl             String?   @map("logo_url")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  // Relations
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions        Subscription[]
  clients              Client[]
  measurementTemplates MeasurementTemplate[]
  orders               Order[]
  payments             Payment[]
  portfolioItems       PortfolioItem[]
  notifications        Notification[]

  @@map("stylists")
}

model SubscriptionPlan {
  id        String   @id @default(uuid())
  name      String   @unique
  price     Int // Prix en FCFA (centimes)
  features  Json // Liste des features incluses
  limits    Json // Limites du plan (clients, commandes, etc.)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                 String             @id @default(uuid())
  stylistId          String             @map("stylist_id")
  planId             String             @map("plan_id")
  status             SubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  // Relations
  stylist Stylist          @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  plan    SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([stylistId])
  @@map("subscriptions")
}

// NextAuth Models
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionToken])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Sprint 2: Client Management Models
model Client {
  id        String    @id @default(uuid())
  stylistId String    @map("stylist_id")
  name      String
  phone     String
  email     String?
  address   String?
  city      String?
  notes     String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  stylist      Stylist             @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  measurements ClientMeasurement[]
  orders       Order[]

  @@index([stylistId])
  @@index([name])
  @@index([phone])
  @@index([stylistId, deletedAt])
  @@map("clients")
}

model MeasurementTemplate {
  id        String    @id @default(uuid())
  stylistId String    @map("stylist_id")
  name      String
  fields    Json // Structure: { fields: [{ name, label, unit, required }] }
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  stylist      Stylist            @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  measurements ClientMeasurement[]

  @@index([stylistId])
  @@map("measurement_templates")
}

model ClientMeasurement {
  id           String   @id @default(uuid())
  clientId     String   @map("client_id")
  templateId   String   @map("template_id")
  measurements Json // Structure: { field_name: value }
  measuredAt   DateTime @map("measured_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  client   Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  template MeasurementTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@index([clientId])
  @@index([templateId])
  @@index([clientId, measuredAt(sort: Desc)])
  @@map("client_measurements")
}

// Sprint 3: Order Management Models
model Order {
  id          String   @id @default(uuid())
  stylistId   String   @map("stylist_id")
  clientId    String   @map("client_id")
  orderNumber String   @unique @map("order_number")

  // Type et description
  garmentType  String  @map("garment_type")
  description  String? @db.Text
  notes        String? @db.Text
  specialRequests String? @db.Text @map("special_requests")

  // Statut
  status             OrderStatus @default(QUOTE)
  cancellationReason String?     @db.Text @map("cancellation_reason")
  canceledAt         DateTime?   @map("canceled_at")

  // Dates
  orderDate          DateTime  @default(now()) @map("order_date")
  promisedDate       DateTime  @map("promised_date")
  actualDeliveryDate DateTime? @map("actual_delivery_date")
  urgencyLevel       UrgencyLevel @default(NORMAL) @map("urgency_level")

  // Tissu
  fabricProvidedBy  FabricProvidedBy @map("fabric_provided_by")
  fabricReceivedDate DateTime?        @map("fabric_received_date")
  fabricDescription  String?          @db.Text @map("fabric_description")

  // Prix (en centimes FCFA)
  totalPrice     Int @map("total_price")
  advanceAmount  Int @default(0) @map("advance_amount")
  totalPaid      Int @default(0) @map("total_paid")
  paymentStatus  PaymentStatus @default(UNPAID) @map("payment_status")

  // Mesures (snapshot au moment de la commande)
  measurementsSnapshot Json? @map("measurements_snapshot")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  stylist       Stylist        @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  photos        OrderPhoto[]
  history       OrderHistory[]
  payments      Payment[]
  notifications Notification[]

  @@index([stylistId])
  @@index([clientId])
  @@index([status])
  @@index([orderNumber])
  @@index([promisedDate])
  @@index([stylistId, status])
  @@index([stylistId, deletedAt])
  @@map("orders")
}

model OrderPhoto {
  id           String    @id @default(uuid())
  orderId      String    @map("order_id")
  photoUrl     String    @map("photo_url")
  thumbnailUrl String?   @map("thumbnail_url")
  storageKey   String?   @map("storage_key")
  thumbnailKey String?   @map("thumbnail_key")
  photoType    PhotoType @map("photo_type")
  caption      String?
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, photoType])
  @@map("order_photos")
}

model OrderHistory {
  id              String          @id @default(uuid())
  orderId         String          @map("order_id")
  changedByUserId String?         @map("changed_by_user_id")
  changeType      OrderChangeType @map("change_type")
  fieldName       String?         @map("field_name")
  oldValue        String?         @db.Text @map("old_value")
  newValue        String?         @db.Text @map("new_value")
  comment         String?         @db.Text
  createdAt       DateTime        @default(now()) @map("created_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, createdAt(sort: Desc)])
  @@map("order_history")
}

// Sprint 4: Payment Model
model Payment {
  id                   String              @id @default(uuid())
  orderId              String              @map("order_id")
  stylistId            String              @map("stylist_id")

  // Montant
  amount               Int                 // En centimes FCFA
  paymentType          PaymentType         @map("payment_type")

  // Méthode
  paymentMethod        PaymentMethod       @map("payment_method")
  mobileMoneyProvider  String?             @map("mobile_money_provider") // "MTN", "Moov", "Orange"
  mobileMoneyNumber    String?             @map("mobile_money_number")
  transactionReference String?             @map("transaction_reference")

  // Statut
  paymentStatus        PaymentRecordStatus @default(COMPLETED) @map("payment_status")
  paymentDate          DateTime            @default(now()) @map("payment_date")

  // Métadonnées
  notes                String?             @db.Text
  receiptUrl           String?             @map("receipt_url")

  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  // Relations
  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stylist  Stylist @relation(fields: [stylistId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([stylistId])
  @@index([paymentDate])
  @@index([stylistId, paymentDate(sort: Desc)])
  @@map("payments")
}

// Sprint 5: Portfolio & Notifications Models
model PortfolioItem {
  id            String   @id @default(uuid())
  stylistId     String   @map("stylist_id")
  imageUrl      String   @map("image_url")
  thumbnailUrl  String?  @map("thumbnail_url")
  title         String
  description   String?  @db.Text
  tags          String[] @default([])
  clientConsent Boolean  @default(false) @map("client_consent")
  isPublished   Boolean  @default(false) @map("is_published")
  viewCount     Int      @default(0) @map("view_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  stylist Stylist @relation(fields: [stylistId], references: [id], onDelete: Cascade)

  @@index([stylistId])
  @@index([stylistId, isPublished])
  @@map("portfolio_items")
}

model Notification {
  id           String             @id @default(uuid())
  stylistId    String             @map("stylist_id")
  orderId      String?            @map("order_id")
  clientId     String             @map("client_id")
  type         NotificationType
  channel      NotificationChannel @default(EMAIL)
  status       NotificationStatus  @default(PENDING)
  sentAt       DateTime?           @map("sent_at")
  errorMessage String?             @db.Text @map("error_message")
  createdAt    DateTime            @default(now()) @map("created_at")

  // Relations
  stylist Stylist @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([stylistId])
  @@index([orderId])
  @@index([stylistId, createdAt(sort: Desc)])
  @@map("notifications")
}

// Sprint 6: Audit Log
model AuditLog {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  action     String   // ex: "SUSPEND_STYLIST", "CHANGE_PLAN", "REACTIVATE_STYLIST"
  targetType String   @map("target_type") // ex: "stylist", "user"
  targetId   String   @map("target_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
