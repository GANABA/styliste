# =============================================================================
# Styliste.com - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env or .env.local to git
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
PUBLIC_APP_URL=http://localhost:5173
NODE_ENV=development
PUBLIC_APP_NAME=Styliste.com

# Default language (fr or en)
PUBLIC_DEFAULT_LOCALE=fr

# -----------------------------------------------------------------------------
# Supabase (Database, Auth, Storage)
# -----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Secret key (NEVER expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database connection string (for Drizzle migrations)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Cloudflare (CDN, Workers, R2 Storage, KV)
# -----------------------------------------------------------------------------
# Get these from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# R2 Storage (for portfolio images)
# Get these from: https://dash.cloudflare.com/r2
PUBLIC_R2_BUCKET_NAME=styliste-portfolios
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
PUBLIC_R2_PUBLIC_URL=https://portfolios.styliste.com

# Cloudflare KV (for cache and sessions)
KV_NAMESPACE_ID=your-kv-namespace-id

# -----------------------------------------------------------------------------
# Notifications - SMS (Termii)
# -----------------------------------------------------------------------------
# Get API key from: https://termii.com/
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=Styliste

# Default country code for SMS (229 for Benin)
DEFAULT_COUNTRY_CODE=229

# -----------------------------------------------------------------------------
# Notifications - WhatsApp (Meta Cloud API)
# -----------------------------------------------------------------------------
# Get these from: https://developers.facebook.com/apps/
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# -----------------------------------------------------------------------------
# Notifications - Email (Resend + React Email)
# -----------------------------------------------------------------------------
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
PUBLIC_EMAIL_FROM=noreply@styliste.com
PUBLIC_EMAIL_FROM_NAME=Styliste.com

# -----------------------------------------------------------------------------
# Payments - Fedapay (Benin - Mobile Money)
# -----------------------------------------------------------------------------
# Get keys from: https://fedapay.com/
FEDAPAY_PUBLIC_KEY=pk_test_your-public-key
FEDAPAY_SECRET_KEY=sk_test_your-secret-key
FEDAPAY_ENVIRONMENT=sandbox
FEDAPAY_WEBHOOK_SECRET=your-webhook-secret

# -----------------------------------------------------------------------------
# Payments - CinetPay (West Africa - Mobile Money)
# -----------------------------------------------------------------------------
# Get keys from: https://cinetpay.com/
CINETPAY_API_KEY=your-cinetpay-api-key
CINETPAY_SITE_ID=your-site-id
CINETPAY_SECRET_KEY=your-cinetpay-secret-key

# -----------------------------------------------------------------------------
# Payments - Stripe (International - Cards)
# -----------------------------------------------------------------------------
# Get keys from: https://dashboard.stripe.com/apikeys
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# -----------------------------------------------------------------------------
# Background Jobs (BullMQ + Redis)
# -----------------------------------------------------------------------------
# Redis connection URL (Railway Redis or other provider)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Queue configuration
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRY=3

# -----------------------------------------------------------------------------
# AI Features (Phase V2 - Optional)
# -----------------------------------------------------------------------------
# OpenAI API key for AI features (model generation, assistant)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# Replicate API for image generation (optional)
REPLICATE_API_TOKEN=your-replicate-token

# -----------------------------------------------------------------------------
# Monitoring & Error Tracking (Sentry)
# -----------------------------------------------------------------------------
# Get DSN from: https://sentry.io/settings/projects/
PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org-name
SENTRY_PROJECT=styliste

# Environment for Sentry (development, staging, production)
SENTRY_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features per environment
ENABLE_AI_FEATURES=false
ENABLE_PORTFOLIO=true
ENABLE_NOTIFICATIONS=true
ENABLE_PAYMENTS=true
ENABLE_WHATSAPP=false

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Requests per minute per IP
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100

# API rate limiting (per API key)
API_RATE_LIMIT=1000

# -----------------------------------------------------------------------------
# Session & Security
# -----------------------------------------------------------------------------
# Session secret for JWT signing (generate a random string)
SESSION_SECRET=your-very-long-random-secret-at-least-32-characters

# Cookie settings
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# -----------------------------------------------------------------------------
# File Upload Limits
# -----------------------------------------------------------------------------
# Maximum file size in bytes (5MB)
MAX_UPLOAD_SIZE=5242880

# Allowed file types for portfolio images
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Maximum number of portfolio images per stylist
MAX_PORTFOLIO_IMAGES=50

# -----------------------------------------------------------------------------
# Subscription Plans Pricing (in FCFA)
# -----------------------------------------------------------------------------
PLAN_FREE_PRICE=0
PLAN_STANDARD_PRICE=5000
PLAN_PRO_PRICE=10000
PLAN_PREMIUM_PRICE=15000

# Limits for free plan
FREE_PLAN_MAX_CLIENTS=10
FREE_PLAN_MAX_ORDERS=5
FREE_PLAN_MAX_NOTIFICATIONS=10

# -----------------------------------------------------------------------------
# Development & Testing
# -----------------------------------------------------------------------------
# Enable debug logs
DEBUG=false

# Bypass authentication (dev only - NEVER in production)
BYPASS_AUTH=false

# Mock external services (for testing)
MOCK_SMS=false
MOCK_WHATSAPP=false
MOCK_EMAIL=false
MOCK_PAYMENTS=false

# Test phone numbers (for development)
TEST_PHONE_NUMBERS=+22900000000,+22900000001

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------
# Google Analytics
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Plausible Analytics (privacy-friendly alternative)
PUBLIC_PLAUSIBLE_DOMAIN=styliste.com

# -----------------------------------------------------------------------------
# i18n (Internationalization)
# -----------------------------------------------------------------------------
SUPPORTED_LOCALES=fr,en
DEFAULT_CURRENCY=XOF
DEFAULT_TIMEZONE=Africa/Porto-Novo
